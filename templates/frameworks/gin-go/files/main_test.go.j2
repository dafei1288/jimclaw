func setupTestRouter() *gin.Engine {
	r := gin.New()
	r.Use(cors.Default())

	// 添加健康检查
	r.GET("/health", healthCheck)

	// 添加根路径
	r.GET("/", func(c *gin.Context) {
		c.JSON(http.StatusOK, gin.H{
			"message": "测试",
			"version": "1.0.0",
		})
	})

	// 404 处理
