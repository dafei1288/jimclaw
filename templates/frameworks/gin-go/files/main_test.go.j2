func TestNotFound(t *testing.T) {
	gin.SetMode(gin.TestMode)
	r := setupTestRouter()

	w := httptest.NewRecorder("GET", "/non-existent", nil)
	r.ServeHTTP(w, nil)

	assert.Equal(t, http.StatusNotFound, w.Code)
}

